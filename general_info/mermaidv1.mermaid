    style DOMICILIO fill:#ff9800,stroke:#ffb74d,color:#fff
    style CONF_INM fill:#4caf50,stroke:#66bb6a,color:#fff
    style CONF_PROG_ASE fill:#4caf50,stroke:#66bb6a,color:#fff
    style NEGOC fill:#ff9800,stroke:#ffb74d,color:#fff
    style HORA_ASE fill:#ff9800,stroke:#ffb74d,color:#fff
    style OFERTA fill:#2196f3,stroke:#42a5f5,color:#fff
    style CONF_HORA fill:#ff9800,stroke:#ffb74d,color:#fff
    style HORA_CLI fill:#2196f3,stroke:#42a5f5,color:#fff
    style DECIDE_ASE fill:#ff9800,stroke:#ffb74d,color:#fff
    style TO_ASE fill:#f44336,stroke:#ef5350,color:#fff
    style MAYOR fill:#e91e63,stroke:#ec407a,color:#fff
    style WAIT_MAYOR fill:#e91e63,stroke:#ec407a,color:#fff
    style RELAY_INIT_W fill:#e91e63,stroke:#ec407a,color:#fff
    style TO_MAYOR fill:#f44336,stroke:#ef5350,color:#fff
    style CONTACTO fill:#2196f3,stroke:#42a5f5,color:#fff
    style CONF_CONTACTO fill:#2196f3,stroke:#42a5f5,color:#fff
    style ASESOR_CONTACTO fill:#2196f3,stroke:#42a5f5,color:#fff
    style DEJA fill:#f44336,stroke:#ef5350,color:#fff
    style MENSAJE fill:#4caf50,stroke:#66bb6a,color:#fff
    style RELAY_INIT_C fill:#e91e63,stroke:#ec407a,color:#fff
    style RELAY fill:#e91e63,stroke:#ec407a,color:#fff
    style RELAY_END fill:#4caf50,stroke:#66bb6a,color:#fff
    style READY fill:#667eea,stroke:#7b9bff,color:#fff
