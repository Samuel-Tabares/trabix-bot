%%{init: {'theme': 'base', 'themeVariables': {
  'background': '#fffaf4',
  'primaryColor': '#f4e3d7',
  'primaryBorderColor': '#d7bda8',
  'primaryTextColor': '#4f4338',
  'secondaryColor': '#e7f0ea',
  'tertiaryColor': '#eef3f6',
  'lineColor': '#c8b19f',
  'clusterBkg': '#fcf5ee',
