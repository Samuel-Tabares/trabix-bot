flowchart LR

    Cliente["Cliente por WhatsApp"] --> Inicio["El bot da la bienvenida"]
    Inicio --> Opciones{"Que quiere hacer?"}

    Opciones -->|Ver menu o horarios| Info["Recibe la informacion y puede volver al inicio"]
    Opciones -->|Hacer pedido| Pedido["Elige entrega, sabores y cantidades"]
    Opciones -->|Hablar con asesor| Asesor["Se conecta con un asesor"]

    Pedido --> Resumen["El bot muestra el resumen y la forma de pago"]
    Resumen --> Datos["El cliente confirma nombre, telefono y direccion"]
    Datos --> Registro[("Pedido registrado")]
    Registro --> Asesor

    Asesor --> Confirmacion["El asesor confirma el pedido o propone una hora"]
    Confirmacion --> Cierre["Cliente recibe la confirmacion final"]
    Cierre --> Menu["La conversacion vuelve al menu principal"]

    Nota["Si ya es tarde, el bot puede ofrecer programar el pedido para despues"]
    Pedido -. apoyo .-> Nota

    classDef cliente fill:#f6d9c9,stroke:#d1a98d,color:#4f4338,stroke-width:1px;
    classDef bot fill:#e8efe8,stroke:#b7c9b9,color:#3f5143,stroke-width:1px;
    classDef decision fill:#f7eedf,stroke:#d7c2a5,color:#5a4b3f,stroke-width:1px;
    classDef data fill:#e8eef6,stroke:#b8c7d9,color:#435160,stroke-width:1px;
    classDef note fill:#fff6cc,stroke:#dccd8a,color:#5d5334,stroke-width:1px;

    class Cliente cliente;
    class Inicio,Info,Pedido,Resumen,Datos,Asesor,Confirmacion,Cierre,Menu bot;
    class Opciones decision;
    class Registro data;
    class Nota note;
