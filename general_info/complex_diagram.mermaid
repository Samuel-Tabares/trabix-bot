%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor':'#667eea', 'primaryBorderColor':'#7b9bff', 'background':'#1e1e2e', 'mainBkg':'#2a2a3a', 'tertiaryBkg':'#333344', 'lineColor':'#7b9bff', 'textColor':'#e0e0e0', 'clusterBkg':'#2a2a3a', 'clusterBorder':'#7b9bff'}}}%%
%% Release baseline: v1.5.1 - 2026-03-26
%% Includes local simulator mode with shared engine/transport, persisted local transcripts/media,
%% simulator transcript timestamps in America/Bogota, active timer inspection/countdowns,
%% simulator-only timer overrides, and timeout source notices for runtime/sweep/boot reconciliation,
%% plus repository distribution metadata under proprietary All Rights Reserved terms,
%% plus cross-platform simulator launch scripts, a fixed tracked real simulator menu asset,
%% top-level README onboarding for local simulator usage,
%% session-centric advisor simulator chat, auto-refresh without manual reload,
%% raw simulator database inspector tabs for conversations/orders/order_items,
%% simulator HTTP handlers centralized under src/simulator/web.rs and frontend assets extracted under assets/simulator/,
%% plus the existing main-menu simplification, America/Bogota SQL sessions,
%% generic customer inactivity reminder/reset only while explicitly armed by inbound customer activity,
%% and 30-minute stuck advisor hard resets.
%% Runtime observability logs masked phone markers, short content previews, state transitions,
%% outbound action summaries, and timer restore/expiry paths while keeping status-only webhooks out of INFO.
%% Narrative runtime and validation reference is consolidated in general_info/current_runtime_reference.md.
graph TD

    WAClient["👤 CLIENTE WHATSAPP"] --> Meta["📡 META CLOUD API"]
    SimClient["🧪 CLIENTE LOCAL"] --> SimUI["🖥️ /simulator UI"]
    SimAdvisor["🧪 ASESOR LOCAL"] --> SimUI
    Meta -->|GET /webhook| Verify["✅ VERIFY WEBHOOK"]
    Meta -->|POST /webhook + X-Hub-Signature-256| Webhook["📥 RECEIVE WEBHOOK"]
    Verify -->|hub.challenge| Meta

    subgraph Runtime["RUST SERVICE GRANIZADO-BOT"]
        Webhook --> HMAC{"🔐 ¿Firma válida?"}
        HMAC -->|No| Reject["401 / ignorar"]
        HMAC -->|Si| Parse["🧩 Parse webhook + describe_input + match contacts/profile"]
        SimUI --> SimParse["🧩 Parse local session + profile name + local media"]
        Parse --> Msg{"💬 ¿Hay mensaje útil?"}
        SimParse --> SimMsg{"💬 ¿Hay mensaje útil?"}
        Msg -->|No| Ignore["200 OK + log"]
        SimMsg -->|No| SimIgnore["UI sin cambio"]
        Msg -->|Si| Route{"from == ADVISOR_PHONE?"}
        SimMsg -->|Si| SimRoute{"actor == advisor?"}
        Route --> Engine["🧠 shared engine<br/>process customer/advisor input<br/>shared action executor"]
        SimRoute --> Engine
    end

    subgraph Persistence["POSTGRESQL + RUNTIME STATE"]
        Conversations["🗂️ conversations<br/>- phone_number<br/>- state<br/>- state_data JSONB<br/>- customer_name<br/>- customer_phone<br/>- delivery_address<br/>- last_message_at<br/>- SQL session TZ America/Bogota"]
        Orders["🧾 orders<br/>- delivery_type<br/>- scheduled_date<br/>- scheduled_time<br/>- payment_method<br/>- receipt_media_id<br/>- delivery_cost<br/>- total_estimated<br/>- total_final<br/>- status"]
        OrderItems["🧊 order_items<br/>- flavor<br/>- has_liquor<br/>- quantity<br/>- unit_price<br/>- subtotal"]
        SimSessions["🧪 simulator_sessions<br/>- customer_phone<br/>- profile_name"]
        SimMessages["💬 simulator_messages<br/>- actor<br/>- audience<br/>- message_kind<br/>- body<br/>- payload JSONB<br/>- created_at timestamp"]
        SimMedia["🖼️ simulator_media<br/>- file_path<br/>- mime_type<br/>- original_filename"]
        Timers["⏱️ runtime timers<br/>- wait_receipt 10m<br/>- advisor_response 2m<br/>- advisor_detail_stuck 30m<br/>- relay_inactivity 30m<br/>- inactivity reminder 2m / reset 35m<br/>- restore_pending_timers()<br/>- sweep_expired_timers()<br/>- simulator UI overrides/countdowns"]
    end

    Engine -->|Cliente| LoadClient["load_or_create_conversation + rehydrate context + seed inbound name/phone"]
    Engine -->|Asesor| LoadAdvisor["load advisor conversation + resolve target phone"]

    LoadClient --> ClientState{"Estado actual"}
    LoadAdvisor --> AdvisorState{"Estado actual del caso"}

    ClientState --> MainMenu

    subgraph CustomerFlow["FLUJO CLIENTE REAL"]
        MainMenu["🤖 MAIN MENU<br/>Bienvenida + horario inmediato 8:00 AM-11:00 PM<br/>Botones: Hacer Pedido / Ver Menú / Hablar con Asesor"] --> MainChoice{"📍 Selección"}

        MainChoice -->|Ver Menu| ViewMenu["view_menu\n- envia imagen Menu\n- envia precios\n- botones Hacer Pedido / Volver al Menu"]
        MainChoice -->|Hacer Pedido| WhenDelivery["when_delivery\nBotones: Entrega Inmediata / Entrega Programada"]
        MainChoice -->|Hablar con Asesor| ContactAdvisorBootstrap["start_contact_advisor"]

        ViewMenu --> MainMenu

        WhenDelivery --> DeliveryChoice{"🕐 delivery_type"}
        DeliveryChoice -->|immediate| CheckHours{"⏰ ¿Bogotá 08:00-23:00?"}
        DeliveryChoice -->|scheduled| SelectDate["📅 select_date<br/>Captura texto libre fecha"]

        CheckHours -->|dentro de horario| OrderNeeds{"📇 ¿Faltan datos del pedido?"}
        CheckHours -->|fuera de horario| OutOfHours["out_of_hours\nTexto + botones Programar / Asesor / Menu"]
        OutOfHours -->|Programar| SelectDate
        OutOfHours -->|Asesor| ContactAdvisorBootstrap
        OutOfHours -->|Menu| MainMenu

        SelectDate --> SelectTime["🕐 select_time<br/>Captura texto libre hora"]
        SelectTime --> ConfirmSchedule["✅ confirm_schedule<br/>Muestra fecha/hora + Confirmar / Cambiar"]
        ConfirmSchedule -->|Confirmar| OrderNeeds
        ConfirmSchedule -->|Cambiar| SelectDate

        OrderNeeds -->|falta nombre| CollectName["collect_name"]
        OrderNeeds -->|falta telefono| CollectPhone["📱 collect_phone"]
        OrderNeeds -->|falta direccion| CollectAddress["📍 collect_address"]
        OrderNeeds -->|completo| SelectType["🧊 select_type<br/>Botones Con Licor / Sin Licor"]
        CollectName --> OrderNeeds
        CollectPhone --> OrderNeeds
        CollectAddress --> OrderNeeds
        SelectType --> SelectFlavor["🍧 select_flavor<br/>Lista según has_liquor"]
        SelectFlavor --> SelectQuantity["🔢 select_quantity<br/>Pregunta cantidad"]
        SelectQuantity --> AddMore["➕ add_more<br/>Resumen parcial + botones"]
        AddMore -->|Agregar más| SelectType
        AddMore -->|Finalizar pedido| ReviewCheckout["📋 review_checkout<br/>render_summary() + botones Continuar / Modificar datos"]
        AddMore -->|Reiniciar pedido| ConfirmRestart["⚠️ confirm_restart_order<br/>confirma borrado total de items"]
        ConfirmRestart -->|Sí, reiniciar| SelectType
        ConfirmRestart -->|No, volver| AddMore

        ReviewCheckout -->|Continuar| AdvisorHandoff["📤 start_order_advisor_flow"]
        ReviewCheckout -->|Modificar datos| SelectField["🛠️ select_customer_data_field<br/>Nombre / Teléfono / Dirección"]
        SelectField -->|Nombre| EditName["✏️ edit_customer_name"]
        SelectField -->|Teléfono| EditPhone["✏️ edit_customer_phone"]
        SelectField -->|Dirección| EditAddress["✏️ edit_customer_address"]
        EditName --> ReviewCheckout
        EditPhone --> ReviewCheckout
        EditAddress --> ReviewCheckout

        SelectPayment["💳 select_payment_method<br/>Botones Contra Entrega / Pago Ahora"] -->|Pago Ahora| WaitReceipt["📸 wait_receipt<br/>- TRANSFER_PAYMENT_TEXT<br/>- pide comprobante<br/>- timer 10m"]
        SelectPayment -->|Contra Entrega| FinalOrder["✅ Confirmación final del pedido<br/>ResetConversation -> MainMenu"]
        WaitReceipt -->|imagen recibida| FinalOrder
        WaitReceipt -->|timer vencido| ReceiptTimeout["Opciones Cambiar pago / Cancelar"]
        ReceiptTimeout --> SelectPayment
    end

    subgraph OrderPersistence["PERSISTENCIA DEL PEDIDO"]
        DraftUpsert["💾 UpsertDraftOrder / FinalizeCurrentOrder<br/>usa conversations + context para orders y order_items"]
        ContextData["🧠 state_data relevante<br/>- items[]<br/>- delivery_type<br/>- scheduled_date<br/>- scheduled_time<br/>- payment_method<br/>- delivery_cost<br/>- total_final<br/>- receipt_media_id<br/>- current_order_id<br/>- advisor timers / relay timers"]
    end

    AdvisorHandoff --> DraftUpsert
    ReviewCheckout --> ContextData
    SelectPayment --> ContextData
    WaitReceipt --> ContextData
    DraftUpsert --> Orders
    DraftUpsert --> OrderItems
    LoadClient --> Conversations
    LoadAdvisor --> Conversations
    Parse --> Conversations
    SimParse --> SimSessions
    Engine --> SimMessages
    Engine --> SimMedia
    Timers --> Conversations

    subgraph OrderAdvisorFlow["FLUJO REAL ASESOR PARA PEDIDOS"]
        AdvisorHandoff --> AskDeliveryCost["ask_delivery_cost\n1. render_order_summary() al asesor\n2. asesor digita domicilio\n3. timer 30m"]
        AskDeliveryCost --> DeliveryTypeAfterCost{"👨‍💼 ¿delivery_type actual?"}

        DeliveryTypeAfterCost -->|scheduled| ScheduledConfirmed["UpdateCurrentOrderDeliveryCost + status=draft_payment\nCliente: subtotal + domicilio + total final + fecha/hora\nLuego botones de pago"]
        DeliveryTypeAfterCost -->|immediate| WaitAdvisorResponse["⏳ wait_advisor_response<br/>asesor recibe solo Confirmar<br/>timer 5m auto-No puedo"]

        WaitAdvisorResponse --> AdvisorDecision{"🔘 Acción del asesor"}
        AdvisorDecision -->|Confirmar| ImmediateConfirmed["UpsertDraftOrder status=draft_payment\nCliente: subtotal + domicilio + total final + 20-40 min\nLuego botones de pago"]
        AdvisorDecision -->|timeout| ConvertToScheduled["Mutaciones:\n- delivery_type = scheduled\n- scheduled_date = hoy Bogota\n- scheduled_time = None\n- limpia proposed/client hour\nLuego pregunta al asesor que hora puede"]
        ConvertToScheduled --> NegotiateHour["🕐 negotiate_hour<br/>timer 30m"]
        NegotiateHour --> AdvisorProposesHour["👨‍💼 Asesor envía texto hora"]
        AdvisorProposesHour --> OfferHourToClient["🎯 offer_hour_to_client<br/>Cliente recibe propuesta + Aceptar / Rechazar"]
        OfferHourToClient --> ClientHourDecision{"🙋 ¿Cliente acepta?"}
        ClientHourDecision -->|Si| WaitAdvisorConfirmHour["✅ wait_advisor_confirm_hour<br/>Asesor recibe botón Confirmar<br/>timer 30m"]
        ClientHourDecision -->|No| WaitClientHour["📝 wait_client_hour<br/>Cliente escribe hora"]

        WaitClientHour --> WaitAdvisorHourDecision["🔁 wait_advisor_hour_decision<br/>Asesor recibe Sí, confirmo / Otra hora<br/>timer 30m"]
        WaitAdvisorHourDecision -->|Si, confirmo| ScheduledConfirmed
        WaitAdvisorHourDecision -->|Otra hora| NegotiateHour
        WaitAdvisorConfirmHour -->|Confirmar| ScheduledConfirmed
    end

    subgraph ContactAdvisorFlow["FLUJO HABLAR CON ASESOR Y RELAY"]
        ContactAdvisorBootstrap --> ContactNeeds{"📇 ¿Faltan datos?"}
        ContactNeeds -->|falta nombre| ContactAdvisorName["contact_advisor_name"]
        ContactNeeds -->|falta telefono| ContactAdvisorPhone["contact_advisor_phone"]
        ContactNeeds -->|completo| ConfirmContact["✅ confirm_address<br/>scope advisor_contact<br/>muestra nombre + telefono"]

        ContactAdvisorName --> ContactNeeds
        ContactAdvisorPhone --> ContactNeeds
        ConfirmContact --> ContactReviewChoice{"📋 ¿Continuar o cambiar?"}
        ContactReviewChoice -->|Continuar| WaitAdvisorContact["wait_advisor_contact\n- render_contact_request al asesor\n- boton Atender\n- cliente queda esperando\n- timer 2m"]
        ContactReviewChoice -->|Cambiar| SelectContactField["🛠️ select_customer_data_field<br/>Nombre / Teléfono"]
        SelectContactField -->|Nombre| EditContactName["✏️ edit_customer_name"]
        SelectContactField -->|Teléfono| EditContactPhone["✏️ edit_customer_phone"]
        EditContactName --> ConfirmContact
        EditContactPhone --> ConfirmContact

        WaitAdvisorContact --> ContactDecision{"Asesor responde?"}
        ContactDecision -->|Atender| RelayMode["🔄 relay_mode<br/>- cliente -> asesor<br/>- asesor -> cliente<br/>- botón Finalizar solo al iniciar relay<br/>- timer 30m"]
        ContactDecision -->|timeout 2m| LeaveOrMenu

        LeaveOrMenu -->|Dejar mensaje| LeaveMessage["leave_message\nCliente deja texto\nBot reenvia al asesor y resetea"]
        LeaveOrMenu -->|Menu| MainMenu
        RelayMode -->|Finalizar o timeout| RelayClosed["Cliente: conversacion finalizada\nResetConversation -> MainMenu"]
    end

    subgraph AdvisorIngress["INGRESO DE MENSAJES DEL ASESOR"]
        AdvisorState --> AdvisorTarget{"📌 ¿Hay target_phone o button_id?"}
        AdvisorTarget -->|No| AdvisorNoTarget["Responder al asesor:\nPrimero usa un boton de un caso pendiente"]
        AdvisorTarget -->|Si| AdvisorTransition["transition_advisor() segun estado del cliente"]
        AdvisorTransition --> OrderAdvisorFlow
        AdvisorTransition --> ContactAdvisorFlow
    end

    subgraph TimerBehavior["TIMERS Y REINICIO"]
        WaitReceipt --> Timers
        WaitAdvisorResponse --> Timers
        WaitAdvisorContact --> Timers
        RelayMode --> Timers
        MainMenu --> Timers
        SelectType --> Timers
        SelectFlavor --> Timers
        SelectQuantity --> Timers
        ShowSummary --> Timers
        ConfirmAddress --> Timers
        SelectField --> Timers
        SelectContactField --> Timers
        EditName --> Timers
        EditPhone --> Timers
        EditAddress --> Timers
        ConfirmContact --> Timers
        EditContactName --> Timers
        EditContactPhone --> Timers
        Timers --> Sweep["⏲️ sweep_expired_timers()<br/>cada 60s"]

        Timers --> ReceiptExpire["expire_receipt_timer\nCliente: no llego comprobante\nBotones Cambiar pago / Cancelar"]
        Timers --> AdvisorExpire["expire_advisor_timer\nPedido inmediato: auto-No puedo a los 5m\nContacto asesor: Dejar mensaje / Menu\nAdvisor-detail waits: hard reset 30m"]
        Timers --> RelayExpire["expire_relay_timer\nCliente: conversacion cerrada por inactividad"]
        Timers --> IdleReminder["conversation_abandon 2m\nReenvia el prompt actual una sola vez"]
        Timers --> IdleReset["conversation_abandon 35m\nNotifica reinicio y resetea a MainMenu"]
        Timers --> Restore["restore_pending_timers al boot\nrehidrata solo timers aun activos\ncatch-up silencioso para expirados\nsin mensajes salientes por reinicio"]
    end

    Engine --> Transport{"🚚 transport mode"}
    Transport -->|production| Meta
    Meta --> WAClient
    Meta --> AdvisorWA["👨‍💼 ASESOR WHATSAPP"]
    Transport -->|simulator| SimUI

    Conversations -.estado y contexto persistido.-> LoadClient
    Orders -.current_order_id / status.-> ContextData
    OrderItems -.items persistidos por pricing lines.-> Orders

    style WAClient fill:#667eea,stroke:#7b9bff,color:#fff
    style MainMenu fill:#667eea,stroke:#7b9bff,color:#fff
    style WhenDelivery fill:#2196f3,stroke:#42a5f5,color:#fff
    style CheckHours fill:#ff9800,stroke:#ffb74d,color:#fff
    style OutOfHours fill:#f44336,stroke:#ef5350,color:#fff
    style SelectDate fill:#9c27b0,stroke:#ba68c8,color:#fff
    style SelectTime fill:#9c27b0,stroke:#ba68c8,color:#fff
    style ConfirmSchedule fill:#8bc34a,stroke:#9ccc65,color:#fff
    style ShowSummary fill:#26a69a,stroke:#4db6ac,color:#fff
    style WaitReceipt fill:#ff7043,stroke:#ff8a65,color:#fff
    style ConfirmAddress fill:#66bb6a,stroke:#81c784,color:#fff
    style AdvisorHandoff fill:#ab47bc,stroke:#ba68c8,color:#fff
    style WaitAdvisorResponse fill:#5c6bc0,stroke:#7986cb,color:#fff
    style AskDeliveryCost fill:#ffa726,stroke:#ffb74d,color:#fff
    style NegotiateHour fill:#26c6da,stroke:#4dd0e1,color:#fff
    style RelayMode fill:#ef5350,stroke:#e57373,color:#fff
    style ScheduledConfirmed fill:#66bb6a,stroke:#81c784,color:#fff
    style ImmediateConfirmed fill:#66bb6a,stroke:#81c784,color:#fff
    style Conversations fill:#424242,stroke:#90a4ae,color:#fff
    style Orders fill:#424242,stroke:#90a4ae,color:#fff
    style OrderItems fill:#424242,stroke:#90a4ae,color:#fff
    style Timers fill:#424242,stroke:#90a4ae,color:#fff
